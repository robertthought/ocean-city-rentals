<% content_for :title, "Find Your Dream Rental | OCNJ Weekly Rentals Concierge" %>
<% content_for :meta_description, "Let our concierge team find your perfect Ocean City, NJ vacation rental. Tell us what you're looking for and we'll match you with the ideal property." %>

<!-- Hero Section -->
<div class="bg-gradient-to-br from-blue-600 via-blue-700 to-cyan-600 text-white">
  <div class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto text-center">
      <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Find Your Dream Rental</h1>
      <p class="text-xl text-blue-100 max-w-2xl mx-auto">
        Can't find the perfect property? Tell us exactly what you're looking for and our concierge team will find it for you.
      </p>
    </div>
  </div>
</div>

<div class="bg-gray-50 py-16">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">

      <% if flash[:notice] %>
        <div class="bg-green-50 border border-green-200 text-green-800 px-6 py-4 rounded-xl mb-8">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="font-semibold"><%= flash[:notice] %></p>
          </div>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 text-red-800 px-6 py-4 rounded-xl mb-8">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div class="bg-white rounded-xl shadow-lg p-8 md:p-12">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Tell Us What You're Looking For</h2>
          <p class="text-gray-600">Fill out as much detail as possible so we can find your perfect match.</p>
        </div>

        <%= form_with url: rental_request_path, method: :post, html: { onsubmit: "executeRecaptcha(this, 'rental_request'); return false;" }, class: "space-y-8" do |f| %>

          <!-- Contact Information -->
          <div class="border-b border-gray-200 pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold">1</span>
              Your Contact Information
            </h3>
            <div class="grid md:grid-cols-3 gap-6">
              <div>
                <%= f.label :name, "Full Name *", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.text_field :name,
                  required: true,
                  placeholder: "John Smith",
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
              <div>
                <%= f.label :email, "Email Address *", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.email_field :email,
                  required: true,
                  placeholder: "john@example.com",
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
              <div>
                <%= f.label :phone, "Phone Number", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.telephone_field :phone,
                  placeholder: "(609) 555-0123",
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
            </div>
          </div>

          <!-- Property Requirements -->
          <div class="border-b border-gray-200 pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold">2</span>
              Property Requirements
            </h3>
            <div class="grid md:grid-cols-3 gap-6">
              <div>
                <%= f.label :bedrooms, "Bedrooms", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.select :bedrooms,
                  options_for_select([
                    ["Any", ""],
                    ["1 Bedroom", 1],
                    ["2 Bedrooms", 2],
                    ["3 Bedrooms", 3],
                    ["4 Bedrooms", 4],
                    ["5 Bedrooms", 5],
                    ["6+ Bedrooms", 6]
                  ]),
                  {},
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
              <div>
                <%= f.label :bathrooms, "Bathrooms", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.select :bathrooms,
                  options_for_select([
                    ["Any", ""],
                    ["1 Bathroom", 1],
                    ["2 Bathrooms", 2],
                    ["3 Bathrooms", 3],
                    ["4+ Bathrooms", 4]
                  ]),
                  {},
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
              <div>
                <%= f.label :sleeps, "Sleeps (# of Guests)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.select :sleeps,
                  options_for_select([
                    ["Any", ""],
                    ["2 Guests", 2],
                    ["4 Guests", 4],
                    ["6 Guests", 6],
                    ["8 Guests", 8],
                    ["10 Guests", 10],
                    ["12+ Guests", 12]
                  ]),
                  {},
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
            </div>
          </div>

          <!-- Dates -->
          <div class="border-b border-gray-200 pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold">3</span>
              When Are You Visiting?
            </h3>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <%= f.label :check_in_date, "Check-in Date", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.date_field :check_in_date,
                  min: Date.today,
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
              <div>
                <%= f.label :check_out_date, "Check-out Date", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.date_field :check_out_date,
                  min: Date.today,
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
            </div>
            <div class="mt-4">
              <label class="flex items-center gap-3 cursor-pointer">
                <%= f.check_box :flexible_dates, class: "w-5 h-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
                <span class="text-gray-700">My dates are flexible (we can adjust by a few days)</span>
              </label>
            </div>
          </div>

          <!-- Location & Budget -->
          <div class="border-b border-gray-200 pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold">4</span>
              Location & Budget
            </h3>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="md:col-span-2">
                <%= f.label :location_preferences, "Preferred Location/Area", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <%= f.text_field :location_preferences,
                  placeholder: "e.g., Close to beach, downtown area, near boardwalk, specific street...",
                  class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                %>
              </div>
              <div>
                <%= f.label :budget_min, "Minimum Budget (per week)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <div class="relative">
                  <span class="absolute left-4 top-3 text-gray-500">$</span>
                  <%= f.number_field :budget_min,
                    placeholder: "1000",
                    min: 0,
                    class: "w-full pl-8 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  %>
                </div>
              </div>
              <div>
                <%= f.label :budget_max, "Maximum Budget (per week)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
                <div class="relative">
                  <span class="absolute left-4 top-3 text-gray-500">$</span>
                  <%= f.number_field :budget_max,
                    placeholder: "5000",
                    min: 0,
                    class: "w-full pl-8 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  %>
                </div>
              </div>
            </div>
          </div>

          <!-- Amenities -->
          <div class="border-b border-gray-200 pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold">5</span>
              Must-Have Amenities
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <% [
                ["Pool", "pool"],
                ["Hot Tub", "hot_tub"],
                ["Ocean View", "ocean_view"],
                ["Pet Friendly", "pet_friendly"],
                ["Parking", "parking"],
                ["WiFi", "wifi"],
                ["A/C", "ac"],
                ["Washer/Dryer", "washer_dryer"],
                ["Grill/BBQ", "grill"],
                ["Beach Gear", "beach_gear"],
                ["Balcony/Deck", "balcony"],
                ["Elevator", "elevator"]
              ].each do |label, value| %>
                <label class="flex items-center gap-2 cursor-pointer p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
                  <input type="checkbox" name="amenities[]" value="<%= value %>" class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                  <span class="text-sm text-gray-700"><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Additional Comments -->
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold">6</span>
              Anything Else We Should Know?
            </h3>
            <%= f.text_area :additional_comments,
              rows: 4,
              placeholder: "Tell us anything else that's important for your ideal vacation rental... special occasions, accessibility needs, specific requests, etc.",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none"
            %>
          </div>

          <!-- Submit -->
          <div class="pt-4">
            <%= f.submit "Submit Rental Request",
              class: "w-full px-6 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-lg shadow-lg hover:shadow-xl transform hover:scale-[1.02] transition-all cursor-pointer"
            %>
            <p class="text-sm text-gray-500 text-center mt-4">
              Our concierge team will review your request and contact you within 24 hours with personalized recommendations.
            </p>
          </div>

        <% end %>
      </div>

      <!-- Why Use Our Concierge -->
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl shadow-md p-6 text-center">
          <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h4 class="font-bold text-gray-900 mb-2">Personalized Matches</h4>
          <p class="text-sm text-gray-600">We hand-pick properties that match your exact needs, not just generic results.</p>
        </div>
        <div class="bg-white rounded-xl shadow-md p-6 text-center">
          <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h4 class="font-bold text-gray-900 mb-2">Fast Response</h4>
          <p class="text-sm text-gray-600">Get recommendations within 24 hours from our local Ocean City experts.</p>
        </div>
        <div class="bg-white rounded-xl shadow-md p-6 text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h4 class="font-bold text-gray-900 mb-2">Free Service</h4>
          <p class="text-sm text-gray-600">Our concierge service is completely free - no fees or obligations.</p>
        </div>
      </div>

    </div>
  </div>
</div>
