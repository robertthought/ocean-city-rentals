<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-start mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @article.title %></h1>
      <p class="text-gray-600">/blog/<%= @article.slug %></p>
    </div>
    <div class="flex gap-3">
      <% if @article.published? %>
        <%= link_to "View Live", article_path(@article), target: "_blank", class: "px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg" %>
        <%= button_to "Unpublish", unpublish_admin_article_path(@article), method: :patch, class: "px-4 py-2 bg-yellow-600 hover:bg-yellow-700 text-white font-semibold rounded-lg" %>
      <% else %>
        <%= button_to "Publish Now", publish_admin_article_path(@article), method: :patch, class: "px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg" %>
      <% end %>
      <%= link_to "Edit", edit_admin_article_path(@article), class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg" %>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-8">
    <!-- Main Content Preview -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl shadow p-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Content Preview</h2>

        <% if @article.featured_image_url.present? %>
          <img src="<%= @article.featured_image_url %>" alt="<%= @article.title %>" class="w-full h-48 object-cover rounded-lg mb-6">
        <% end %>

        <div class="prose max-w-none">
          <%= simple_format(@article.content.to_s.gsub(/\*\*(.+?)\*\*/, '<strong>\1</strong>').html_safe) %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Status Card -->
      <div class="bg-white rounded-xl shadow p-6">
        <h3 class="font-bold text-gray-900 mb-4">Status</h3>
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-600">Status</span>
            <% if @article.published? %>
              <span class="px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Published</span>
            <% else %>
              <span class="px-2 py-1 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">Draft</span>
            <% end %>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Author</span>
            <span class="text-gray-900"><%= @article.author %></span>
          </div>
          <% if @article.published_at %>
            <div class="flex justify-between">
              <span class="text-gray-600">Published</span>
              <span class="text-gray-900"><%= @article.published_at.strftime("%b %d, %Y") %></span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span class="text-gray-600">Created</span>
            <span class="text-gray-900"><%= @article.created_at.strftime("%b %d, %Y") %></span>
          </div>
        </div>
      </div>

      <!-- SEO Card -->
      <div class="bg-white rounded-xl shadow p-6">
        <h3 class="font-bold text-gray-900 mb-4">SEO</h3>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-gray-500 mb-1">Category</p>
            <p class="text-gray-900"><%= @article.category.presence || "—" %></p>
          </div>
          <div>
            <p class="text-sm text-gray-500 mb-1">Meta Description</p>
            <p class="text-gray-900 text-sm"><%= @article.meta_description.presence || "Auto-generated from content" %></p>
          </div>
          <div>
            <p class="text-sm text-gray-500 mb-1">Tags</p>
            <% if @article.tag_list.any? %>
              <div class="flex flex-wrap gap-1">
                <% @article.tag_list.each do |tag| %>
                  <span class="bg-gray-100 text-gray-700 px-2 py-0.5 rounded text-xs"><%= tag %></span>
                <% end %>
              </div>
            <% else %>
              <p class="text-gray-400">—</p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Actions Card -->
      <div class="bg-white rounded-xl shadow p-6">
        <h3 class="font-bold text-gray-900 mb-4">Actions</h3>
        <div class="space-y-3">
          <%= link_to "Edit Article", edit_admin_article_path(@article), class: "block w-full text-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg" %>
          <%= button_to "Delete Article", admin_article_path(@article), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this article?" }, class: "block w-full text-center px-4 py-2 bg-red-100 hover:bg-red-200 text-red-700 font-semibold rounded-lg" %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <%= link_to "← Back to Articles", admin_articles_path, class: "text-blue-600 hover:text-blue-700 font-semibold" %>
  </div>
</div>
