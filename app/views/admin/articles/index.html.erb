<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Blog Articles</h1>
      <p class="text-gray-600">Manage your blog content for SEO</p>
    </div>
    <%= link_to "New Article", new_admin_article_path,
      class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg" %>
  </div>

  <!-- Filter Tabs -->
  <div class="flex gap-4 mb-6">
    <%= link_to "All", admin_articles_path,
      class: "px-4 py-2 rounded-lg font-medium #{params[:status].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <%= link_to "Published", admin_articles_path(status: "published"),
      class: "px-4 py-2 rounded-lg font-medium #{params[:status] == 'published' ? 'bg-green-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <%= link_to "Drafts", admin_articles_path(status: "draft"),
      class: "px-4 py-2 rounded-lg font-medium #{params[:status] == 'draft' ? 'bg-yellow-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
  </div>

  <% if @articles.any? %>
    <div class="bg-white rounded-xl shadow overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @articles.each do |article| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4">
                <div class="font-medium text-gray-900"><%= article.title %></div>
                <div class="text-sm text-gray-500">/blog/<%= article.slug %></div>
              </td>
              <td class="px-6 py-4">
                <% if article.category.present? %>
                  <span class="px-2 py-1 text-xs font-medium bg-gray-100 rounded"><%= article.category %></span>
                <% else %>
                  <span class="text-gray-400">—</span>
                <% end %>
              </td>
              <td class="px-6 py-4">
                <% if article.published? %>
                  <span class="px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Published</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">Draft</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <% if article.published_at %>
                  <%= article.published_at.strftime("%b %d, %Y") %>
                <% else %>
                  Created <%= article.created_at.strftime("%b %d, %Y") %>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right text-sm">
                <%= link_to "Edit", edit_admin_article_path(article), class: "text-blue-600 hover:text-blue-800 mr-3" %>
                <%= link_to "View", admin_article_path(article), class: "text-gray-600 hover:text-gray-800" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if @pagy.pages > 1 %>
      <div class="flex justify-center mt-6">
        <nav class="flex items-center gap-2">
          <% if @pagy.prev %>
            <%= link_to admin_articles_path(page: @pagy.prev, status: params[:status]),
                class: "px-3 py-2 bg-white border rounded hover:bg-gray-50" do %>
              &larr; Previous
            <% end %>
          <% end %>
          <span class="px-4 py-2 text-gray-600">Page <%= @pagy.page %> of <%= @pagy.pages %></span>
          <% if @pagy.next %>
            <%= link_to admin_articles_path(page: @pagy.next, status: params[:status]),
                class: "px-3 py-2 bg-white border rounded hover:bg-gray-50" do %>
              Next &rarr;
            <% end %>
          <% end %>
        </nav>
      </div>
    <% end %>

  <% else %>
    <div class="bg-white rounded-xl shadow p-12 text-center">
      <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
      </svg>
      <h3 class="text-xl font-bold text-gray-900 mb-2">No articles yet</h3>
      <p class="text-gray-600 mb-6">Create your first blog post to boost SEO.</p>
      <%= link_to "Create Your First Article", new_admin_article_path,
        class: "inline-block px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg" %>
    </div>
  <% end %>
</div>
