<%= form_with model: [:admin, @article], class: "space-y-6" do |f| %>
  <% if @article.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% @article.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow p-6 space-y-6">
    <h2 class="text-xl font-bold text-gray-900">Article Details</h2>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Enter article title" %>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <%= f.label :category, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :category, Article::CATEGORIES.map { |c| [c, c] }, { include_blank: "Select category" }, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :author, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :author, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>
    </div>

    <div>
      <%= f.label :featured_image_url, "Featured Image URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :featured_image_url, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "https://example.com/image.jpg" %>
      <p class="mt-1 text-sm text-gray-500">Recommended size: 1200x630px for optimal social sharing</p>
    </div>

    <div>
      <%= f.label :meta_description, "Meta Description (SEO)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :meta_description, rows: 2, maxlength: 160, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Brief description for search engines (max 160 characters)" %>
      <p class="mt-1 text-sm text-gray-500">
        <span id="meta-char-count"><%= @article.meta_description.to_s.length %></span>/160 characters
      </p>
    </div>

    <div>
      <%= f.label :tags, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :tags, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "beach, vacation, summer (comma-separated)" %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Content</h2>

    <div>
      <%= f.label :content, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :content, rows: 20, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent font-mono text-sm", placeholder: "Write your article content here...\n\nYou can use **bold text** for emphasis." %>
      <p class="mt-1 text-sm text-gray-500">Use **text** for bold. Content will be automatically formatted into paragraphs.</p>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Publishing</h2>

    <div class="flex items-center gap-4">
      <div class="flex items-center">
        <%= f.check_box :published, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <%= f.label :published, "Publish immediately", class: "ml-2 text-sm text-gray-700" %>
      </div>

      <div class="flex-1">
        <%= f.label :published_at, "Or schedule for:", class: "text-sm text-gray-700 mr-2" %>
        <%= f.datetime_local_field :published_at, class: "px-3 py-1 border border-gray-300 rounded-lg text-sm" %>
      </div>
    </div>
  </div>

  <div class="flex justify-between">
    <%= link_to "Cancel", admin_articles_path, class: "px-6 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-lg" %>

    <div class="flex gap-3">
      <%= f.submit "Save as Draft", name: "draft", class: "px-6 py-3 bg-gray-600 hover:bg-gray-700 text-white font-semibold rounded-lg cursor-pointer" %>
      <%= f.submit "Save & Publish", class: "px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg cursor-pointer" %>
    </div>
  </div>
<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const metaField = document.querySelector('textarea[name="article[meta_description]"]');
    const charCount = document.getElementById('meta-char-count');

    if (metaField && charCount) {
      metaField.addEventListener('input', function() {
        charCount.textContent = this.value.length;
      });
    }
  });
</script>
